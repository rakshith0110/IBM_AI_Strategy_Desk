# ======================================
# OLLAMA CONFIGURATION
# ======================================
# No API key needed for local Ollama!
# Just make sure Ollama is running locally with:
# ollama serve

# Optional: Customize Ollama host if not using default
# OLLAMA_HOST=http://localhost:11434

# ======================================
# MODEL CONFIGURATION
# ======================================
# Default model used: llama3.1
# To use a different model, pull it first:
# ollama pull llama3.1
# ollama pull mistral
# ollama pull codellama

# Then update the model name in the Python files